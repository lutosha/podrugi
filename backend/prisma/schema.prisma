// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String
  name          String
  city          String?
  ageConfirmed  Boolean   @default(false)
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  posts         Post[]
  comments      Comment[]
  rsvps         Rsvp[]
  reportsMade     Report[] @relation("ReportsMade")
  reportsAgainst  Report[] @relation("ReportsAgainst")
  blocksMade      Block[]  @relation("BlocksMade")
  blocksReceived  Block[]  @relation("BlocksReceived")
}

enum PostType {
  POST
  ANNOUNCEMENT
  EVENT
}

enum RsvpStatus {
  GOING
  MAYBE
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model Report {
  id             Int          @id @default(autoincrement())
  reason         String
  status         ReportStatus @default(PENDING)
  reporterId     Int
  reporter       User         @relation("ReportsMade", fields: [reporterId], references: [id])
  reportedPostId Int?
  reportedPost   Post?        @relation(fields: [reportedPostId], references: [id])
  reportedUserId Int?
  reportedUser   User?        @relation("ReportsAgainst", fields: [reportedUserId], references: [id])
  createdAt      DateTime     @default(now())
}

model Block {
  id        Int      @id @default(autoincrement())
  blockerId Int
  blocker   User     @relation("BlocksMade", fields: [blockerId], references: [id])
  blockedId Int
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [id])
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model Post {
  id        Int        @id @default(autoincrement())
  type      PostType   @default(POST)
  content   String
  area      String?
  eventDate DateTime?
  authorId  Int
  author    User       @relation(fields: [authorId], references: [id])
  createdAt DateTime   @default(now())
  comments  Comment[]
  rsvps     Rsvp[]
  reports   Report[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}

model Rsvp {
  id        Int        @id @default(autoincrement())
  status    RsvpStatus
  postId    Int
  post      Post       @relation(fields: [postId], references: [id])
  userId    Int
  user      User       @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now())

  @@unique([postId, userId])
}
